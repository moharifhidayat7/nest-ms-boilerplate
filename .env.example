# Server
PORT=3000
SERVICE_NAME=your-service-name
NODE_ENV=development

# Database — individual
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=your_db_name

# Database — connection string (used by Prisma CLI)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/your_db_name

# Auth — Internal
INTERNAL_JWT_SECRET=change-this-to-a-random-secret

# Auth — External
AUTH_SERVICE_URL=http://auth-service:4000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
