{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "transformIgnorePatterns": ["/node_modules/(?!.*\\.ts$)"],
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "useESM": false, "tsconfig": "test/tsconfig.json" }]
  },
  "moduleNameMapper": {
    "@app/prisma": "<rootDir>/test/__mocks__/prisma-client.ts",
    "^.+generated/prisma/client$": "<rootDir>/test/__mocks__/prisma-client.ts"
  }
}
